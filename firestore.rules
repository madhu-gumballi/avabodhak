rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Progress subcollection (legacy)
      match /progress/{stotraId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Practice progress subcollection
      match /practiceProgress/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Puzzle progress subcollection
      match /puzzleProgress/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Stotra completion counts subcollection
      match /stotraCompletions/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Feedback collection - authenticated users can create and read their own feedback
    match /feedback/{feedbackId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Leaderboard collection - anyone authenticated can read, only cloud functions can write
    match /leaderboard/{period} {
      allow read: if request.auth != null;
      // For now, allow authenticated users to write their own entry
      // In production, use Cloud Functions for this
      allow write: if request.auth != null;
    }

    // textIssues — full reports with user identity, verifier/admin only read
    match /textIssues/{issueId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        in ['verifier', 'admin'];
    }

    // publicIssues — privacy-stripped projection, all auth users read
    match /publicIssues/{issueId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        in ['verifier', 'admin'];
    }

    // textQualitySummary — all auth users read and write
    // Any authenticated user may increment counts when they submit an issue.
    // Verifier/admin controls are enforced in textIssues and publicIssues.
    match /textQualitySummary/{stotraKey} {
      allow read, write: if request.auth != null;
    }
  }
}
